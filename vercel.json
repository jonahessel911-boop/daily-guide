{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/dispocam/?", "dest": "/", "status": 308 },
    {
      "src": "/dispocam/(checkout|pay|missie|feed|about)(\\.html)?/?",
      "dest": "/$1",
      "status": 308
    },
    {
      "src": "/(checkout|pay|missie|feed|about)\\.html",
      "dest": "/$1",
      "status": 308
    },
    {
      "src": "/(checkout|pay|missie|feed|about)/?",
      "dest": "/$1.html"
    },
    { "handle": "filesystem" },
    { "src": "/api/(.*)", "dest": "server.js" },
    { "src": "/(.*)", "dest": "server.js" }
  ]
}
